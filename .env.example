# ── FREE STACK (required) ────────────────────────────────────────────────────
# Get a free Groq key at https://console.groq.com  (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
# ── OPTIONAL OVERRIDES ────────────────────────────────────────────────────────
# Embedding model (default: all-MiniLM-L6-v2, runs locally)
# EMBED_MODEL=all-MiniLM-L6-v2

# Groq model (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.3-70b-versatile

# Chunk settings
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# TOP_K_RESULTS=5

# ── PAID ALTERNATIVES (leave blank if using free stack) ──────────────────────
# OPENAI_API_KEY=
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=medical-rag
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=
